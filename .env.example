# New Relic Configuration
NEW_RELIC_API_KEY=NRAK-XXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEW_RELIC_ACCOUNT_ID=1234567
NEW_RELIC_REGION=US

# Dynatrace Configuration
DYNATRACE_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
DYNATRACE_ENVIRONMENT_URL=https://abc12345.live.dynatrace.com

# Migration Settings (Optional)
MIGRATION_DRY_RUN=false
MIGRATION_OUTPUT_DIR=./output
MIGRATION_BATCH_SIZE=50
MIGRATION_RATE_LIMIT=5.0
MIGRATION_CONTINUE_ON_ERROR=true
MIGRATION_BACKUP=true
LOG_LEVEL=INFO

# Gen2 / classic-tenant compatibility. Leave false unless your Dynatrace
# tenant is missing Gen3 features (Workflows, Segments, OpenPipeline,
# Document API). When true, the migrator routes through
# clients/legacy/, transformers/legacy/, and exporters/legacy/.
# Equivalent to passing --legacy on the CLI.
MIGRATION_LEGACY_MODE=false

# OAuth2 platform-token credentials (required for the Gen3 Automation
# API and Document API if your tenant needs bearer auth). Leave blank
# when an Api-Token is sufficient.
DT_CLIENT_ID=
DT_CLIENT_SECRET=
