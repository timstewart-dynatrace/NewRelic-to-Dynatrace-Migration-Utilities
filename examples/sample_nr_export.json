      },
      "tags": [
        { "key": "environment", "values": ["production"] },
        { "key": "team", "values": ["platform"] }
      ]
    },
    {
      "guid": "synth-002",
      "name": "API Login Flow",
      "monitorType": "SCRIPT_API",
      "monitoredUrl": "https://api.example.com/auth/login",
      "period": "EVERY_15_MINUTES",
      "status": "ENABLED",
      "monitorSummary": {
        "status": "PASSING",
        "successRate": 100.0
      },
      "tags": [
        { "key": "environment", "values": ["production"] }
      ]
    },
    {
      "guid": "synth-003",
      "name": "Checkout Flow",
      "monitorType": "BROWSER",
      "monitoredUrl": "https://www.example.com/checkout",
      "period": "EVERY_30_MINUTES",
      "status": "ENABLED",
      "monitorSummary": {
        "status": "PASSING",
        "successRate": 97.5
      },
      "tags": [
        { "key": "environment", "values": ["production"] },
        { "key": "critical", "values": ["true"] }
      ]
    }
  ],
  "slos": [
    {
      "guid": "slo-001",
      "name": "API Availability",
      "description": "99.9% of API requests should return a successful response",
      "objectives": [
        {
          "target": 99.9,
          "timeWindow": {
            "rolling": { "count": 7, "unit": "DAY" }
          }
        }
      ],
      "events": {
        "validEvents": {
          "from": "Transaction",
          "where": "request.uri LIKE '/api/%'"
        },
        "goodEvents": {
          "from": "Transaction",
          "where": "request.uri LIKE '/api/%' AND httpResponseCode < 500"
        }
      }
    },
    {
      "guid": "slo-002",
      "name": "Checkout Latency",
      "description": "95% of checkout requests should complete within 3 seconds",
      "objectives": [
        {
          "target": 95.0,
          "timeWindow": {
            "rolling": { "count": 30, "unit": "DAY" }
          }
        }
      ],
      "events": {
        "validEvents": {
          "from": "Transaction",
          "where": "name = 'WebTransaction/checkout'"
        },
        "goodEvents": {
          "from": "Transaction",
          "where": "name = 'WebTransaction/checkout' AND duration < 3"
        }
      }
    }
  ],
  "workloads": [
    {
      "guid": "workload-001",
      "name": "E-Commerce Platform",
      "collection": [
        { "guid": "entity-001", "name": "checkout-service", "type": "APM_APPLICATION" },
